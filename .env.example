APP_ENV=dev
APP_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:3000
# Host-local defaults for "Full Stack Local Start".
DATABASE_URL=sqlite:///output/platform.db
SESSION_SECRET=change-me-session-secret
# Optional in dev. Required in production. Generate with:
# python -c "from tiktok_platform.token_crypto import generate_token_encryption_key; print(generate_token_encryption_key())"
TOKEN_ENCRYPTION_KEY=
MEDIA_ROOT=storage
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_FROM_EMAIL=alerts@example.com
LAB_ENABLED=true
UPLOAD_MODE=hybrid
TIKTOK_SIMULATE_UPLOADS=true
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
PIPELINE_CONFIG_PATH=config/pipeline.example.json

# Docker overrides (use these values when running docker compose):
# DATABASE_URL=postgresql+psycopg://platform:platform@postgres:5432/platform
# MEDIA_ROOT=/app/storage
# PIPELINE_CONFIG_PATH=/app/config/pipeline.example.json
